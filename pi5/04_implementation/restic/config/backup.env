# Restic environment configuration
# Live file: /etc/restic/backup.env
# Passwords and secrets are not committed — redacted below

RESTIC_REPOSITORY=/mnt/backup/restic
RESTIC_PASSWORD_FILE=/etc/restic/backup.pass   # not committed
RESTIC_CACHE_DIR=/var/cache/restic
RESTIC_ENV_FILE=/etc/restic/backup.env
RESTIC_EXCLUDES=/etc/restic/excludes.txt
RESTIC_KEEP_LAST=30
RESTIC_NOTIFY_TO=xindy.notifications@gmail.com
RESTIC_NOTIFY_FROM=xindy.notifications@gmail.com
RESTIC_LOG=/var/log/restic/backup.log

# Cloudflare R2 offsite repository
RESTIC_R2_REPOSITORY=s3:https://<account-id>.r2.cloudflarestorage.com/rootnode-restic
RESTIC_R2_ACCESS_KEY_ID=<redacted>       # not committed
RESTIC_R2_SECRET_ACCESS_KEY=<redacted>   # not committed
RESTIC_R2_KEEP_LAST=2
